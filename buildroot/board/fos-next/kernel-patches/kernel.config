# fos-next x86_64 kernel config fragment
# Base: x86_64 defconfig, then apply this fragment.
# Buildroot applies this on top of the base defconfig.

# ── Mandatory for imaging ─────────────────────────────────────────────────────

# Block devices
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_NVME=y

# SCSI
CONFIG_SCSI=y
CONFIG_SCSI_DMA=y
CONFIG_BLK_DEV_SR=y

# USB storage
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_HID=y         # keyboard for debug console
CONFIG_HID_GENERIC=y

# VirtIO (required for VM-based testing)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_NTFS_FS=y
CONFIG_NTFS3_FS=y
CONFIG_VFAT_FS=y
CONFIG_XFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Network
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IP_PNP=y
CONFIG_IP_PNP_DHCP=y
CONFIG_PACKET=y
CONFIG_NETDEVICES=y

# Common NIC drivers
CONFIG_E1000=y
CONFIG_E1000E=y
CONFIG_IGB=y
CONFIG_IXGBE=y
CONFIG_I40E=y
CONFIG_ICE=y
CONFIG_VMXNET3=y
CONFIG_TG3=y
CONFIG_BNX2=y

# Realtek (in-tree)
CONFIG_R8169=y
CONFIG_8139CP=y
CONFIG_8139TOO=y

# Serial console (for dmesg/kmsg visibility)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# printk / kmsg
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y

# Initramfs decompression — must match BR2_TARGET_ROOTFS_CPIO_XZ
CONFIG_RD_XZ=y

# ── Explicitly disabled ───────────────────────────────────────────────────────

# ARM-specific drivers — not applicable on x86
# CONFIG_ARM_AMBA is not set

# Staging drivers (unstable)
CONFIG_STAGING=n

# Debug options (reduce kernel size)
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_KASAN=n
CONFIG_KCSAN=n
CONFIG_UBSAN=n
